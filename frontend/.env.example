# Supabase project URL. Use https://your-project-ref.supabase.co
# Do not use the REST URL ending in /rest/v1.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key. This is safe to expose to browser code.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Server-only. Never prefix with NEXT_PUBLIC_.
# Used only by /api/delete-account to delete the signed-in auth user.
SUPABASE_SERVICE_ROLE_KEY=
